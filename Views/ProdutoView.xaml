<Window x:Class="challange_by_coodesh.Views.ProdutoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:challange_by_coodesh.Views"
        mc:Ignorable="d"
        Title="Cadastro de Produtos" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- HEADER -->

        <Border Grid.Row="0"
                Background="#FFF"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            
            <TextBlock Text="Cadastro de Produtos"
                       FontSize="20"
                       FontWeight="SemiBold"
                       TextAlignment="Center"/>
        </Border>
        
        <!-- FORM -->
        <Border Grid.Row="1"
                Background="#FFF"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ID -->
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Id"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,10,15"/>
                <TextBox x:Name="txtId"
                         Grid.Row="0"
                         Grid.Column="1"
                         Height="35"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Background="#EDF2F7"
                         Margin="0,0,20,15"/>

                <!-- NOME -->
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Nome"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,15"/>
                <TextBox x:Name="txtNome"
                         Grid.Row="1"
                         Grid.Column="1"
                         VerticalContentAlignment="Center"
                         Height="35"
                         Margin="0,0,20,15"/>

                <!-- Codigo -->
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Text="Código Produto"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,10,15"/>
                <TextBox x:Name="txtCodigoProduto"
                         Grid.Row="1"
                         Grid.Column="3"
                         Height="35"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,15"/>

                <!--Valor-->
                <TextBlock Grid.Row="1"
                           Grid.Column="4"
                           Text="Valor"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,10,15"/>

                <TextBox x:Name="txtValor"
                         Grid.Row="1"
                         Grid.Column="5"
                         Height="35"
                         VerticalContentAlignment="Center"
                         Margin="0,0,20,15"/>

                <!-- Filtro -->
                <StackPanel Grid.Row="3" 
                            Grid.Column="0" 
                            Grid.ColumnSpan="6" 
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0">

                    <TextBlock Text="Filtrar por:" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold" 
                               Margin="0,0,10,0"/>

                    <TextBlock Text="Nome" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold"
                               Margin="0,0,5,0"/>

                    <TextBox x:Name="txtFiltrarNomeProduto" 
                             Width="220" 
                             Height="35" 
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E0"  
                             ToolTip="Pesquisar por nome do produto"/>

                    <TextBlock Text="Código Produto" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold"
                               Margin="0,0,5,0"/>

                    <TextBox x:Name="txtFiltrarCodigoProduto" 
                             Width="100" 
                             Height="35" 
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E0"  
                             ToolTip="Pesquisar por código do produto"/>

                    <TextBlock Text="Valor Inicial" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold"
                               Margin="0,0,5,0"/>

                    <TextBox x:Name="txtFiltrarValorInicial" 
                             Width="100" 
                             Height="35" 
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E0"  
                             ToolTip="Pesquisar por valor inicial"/>

                    <TextBlock Text="Valor Final" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold"
                               Margin="0,0,5,0"/>

                    <TextBox x:Name="txtFiltrarValorFinal" 
                             Width="100" 
                             Height="35" 
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E0"  
                             ToolTip="Pesquisar por valor final"/>

                    <Button x:Name="BtnPesquisarProduto" Content="Pesquisar" 
                            Width="120"
                            Height="35"
                            Background="#3182CE" 
                            Foreground="#FFF" 
                            BorderBrush="#3182CE"
                            BorderThickness="0" 
                            Cursor="Hand"/>
                </StackPanel>

            </Grid>
        </Border>
        
        <!-- GRID -->
        <Border Grid.Row="2"
                Background="#FFF"
                CornerRadius="12"
                Padding="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!--Buttons -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,20">

                    <Button x:Name="txtIncluirProduto"
                            Content="Incluir"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,0"
                            Background="#38A169"
                            Foreground="#FFF"/>

                    <Button x:Name="txtEditarProduto"
                            Content="Editar"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,0"
                            Background="#DD6B20"
                            Foreground="#FFF"/>

                    <Button x:Name="txtSalvarProduto"
                            Content="Salvar"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,0"
                            Background="#3182CE"
                            Foreground="#FFF"/>

                    <Button x:Name="txtExcluirProduto"
                            Content="Excluir"
                            Width="110"
                            Height="35"
                            Margin="0,0,20,0"
                            Background="#E53E3E"
                            Foreground="#FFF"/>
                </StackPanel>
                
                <!-- Grid -->
                <DataGrid x:Name="dgProdutos"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeight="35">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id"
                                            Width="100"
                                            Binding="{Binding Id}"/>

                        <DataGridTextColumn Header="Nome"
                                            Width="*"
                                            Binding="{Binding Nome}"/>

                        <DataGridTextColumn Header="Código"
                                            Width="200"
                                            Binding="{Binding CodigoProduto}"/>

                        <DataGridTextColumn Header="Valor"
                                            Width="150"
                                            Binding="{Binding Valor}"/>
                    </DataGrid.Columns>
                    
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</Window>
