<Window x:Class="challange_by_coodesh.Views.ProdutoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:challange_by_coodesh.Views"
        mc:Ignorable="d"
        Title="Cadastro de Produtos" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA" Icon="/Resources/Icons/logo-benner.png" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Grid.Row="0"
                Background="#FFF"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">

            <TextBlock Text="Cadastro de Produtos"
                       FontSize="20"
                       FontWeight="SemiBold"
                       TextAlignment="Center"/>
        </Border>

        <!-- FORM -->
        <Border Grid.Row="1"
                Background="#FFF"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ID -->
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Id"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,10,15"/>
                <TextBox x:Name="txtId"
                         Grid.Row="0"
                         Grid.Column="1"
                         Height="35"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Background="#EDF2F7"
                         Margin="0,0,20,15"/>

                <!-- NOME -->
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Nome"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,15"/>
                <TextBox x:Name="txtNome"
                         Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="3"
                         VerticalContentAlignment="Center"
                         Height="35"
                         Margin="0,0,170,15"/>

                <!-- Codigo -->
                <TextBlock Grid.Row="1"
                           Grid.Column="3"
                           Text="Código Produto"
                           VerticalAlignment="Top"
                           FontWeight="SemiBold"
                           Margin="140,10,70,0"/>
                <TextBox x:Name="txtCodigoProduto"
                         Grid.Row="1"
                         Grid.Column="3"
                         Height="35"
                         VerticalContentAlignment="Center"
                         Margin="240,0,200,15" 
                         Grid.ColumnSpan="3"/>

                <!--Valor-->
                <TextBlock Grid.Row="1"
                           Grid.Column="5"
                           Text="Valor"
                           TextAlignment="Center"
                           VerticalAlignment="Top"
                           FontWeight="SemiBold"
                           Margin="104,10,138,0" RenderTransformOrigin="3.422,0.622"/>

                <TextBox x:Name="txtValor"
                         Grid.Row="1"
                         Grid.Column="5"
                         Height="35"
                         VerticalContentAlignment="Center"
                         Margin="165,0,20,15" PreviewTextInput="txtValor_PreviewTextInput"/>

                <!-- Filtro -->
                <StackPanel Grid.Row="3" 
                            Grid.Column="0" 
                            Grid.ColumnSpan="6" 
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0">

                    <TextBlock Text="Filtrar por:" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold" 
                               Margin="0,0,10,0"/>

                    <TextBlock Text="Nome" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold"
                               Margin="0,0,5,0"/>

                    <TextBox x:Name="txtFiltrarNomeProduto" 
                             Width="220" 
                             Height="35" 
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E0"  
                             ToolTip="Pesquisar por nome do produto"/>

                    <TextBlock Text="Código Produto" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold"
                               Margin="0,0,5,0"/>

                    <TextBox x:Name="txtFiltrarCodigoProduto" 
                             Width="100" 
                             Height="35" 
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E0"  
                             ToolTip="Pesquisar por código do produto"/>

                    <TextBlock Text="Valor Inicial" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold"
                               Margin="0,0,5,0"/>

                    <TextBox x:Name="txtFiltrarValorInicial" 
                             Width="100" 
                             Height="35" 
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E0"  
                             PreviewTextInput="txtValor_PreviewTextInput"
                             ToolTip="Pesquisar por valor inicial"/>

                    <TextBlock Text="Valor Final" 
                               VerticalAlignment="Center" 
                               FontWeight="SemiBold"
                               Margin="0,0,5,0"/>

                    <TextBox x:Name="txtFiltrarValorFinal" 
                             Width="100" 
                             Height="35" 
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E0"  
                             PreviewTextInput="txtValor_PreviewTextInput"
                             ToolTip="Pesquisar por valor final"/>

                    <Button x:Name="BtnPesquisarProduto" 
                            Width="120"
                            Height="35"
                            Foreground="#000" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            Click="BtnPesquisarProduto_Click">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Image Source="/Resources/Icons/search.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,8,0"/>

                            <TextBlock Text="Pesquisar" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <!-- GRID -->
        <Border Grid.Row="2"
                Background="#FFF"
                CornerRadius="12"
                Padding="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!--Buttons -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,20" Cursor="Hand">

                    <Button x:Name="BtnIncluir"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,0"
                            Foreground="#000" Click="txtIncluir_Click" Cursor="Hand">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                            <Image Source="/Resources/Icons/add.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,8,0"/>

                            <TextBlock Text="Incluir"
                                       VerticalAlignment="Center"/>

                        </StackPanel>
                    </Button>


                    <Button x:Name="txtEditarProduto"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,0"
                            Foreground="#000" Click="txtEditarProduto_Click" 
                            Cursor="Hand">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Image Source="/Resources/Icons/edit.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,8,0"/>
                            
                            <TextBlock Text="Editar"
                                       VerticalAlignment="Center"/>

                        </StackPanel>
                    </Button>

                    <Button x:Name="txtSalvarProduto"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Foreground="#000" 
                        Click="txtSalvarProduto_Click" 
                        Cursor="Hand">

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">

                            <Image Source="/Resources/Icons/save.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,8,0"/>

                            <TextBlock Text="Salvar" 
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="txtExcluirProduto"
                            Width="110"
                            Height="35"
                            Margin="0,0,20,0"
                            Foreground="#000" 
                            Click="txtExcluirProduto_Click" 
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Image Source="/Resources/Icons/delete.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,8,0"/>
                            <TextBlock Text="Excluir" 
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Grid -->
                <DataGrid x:Name="dgProdutos"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowHeight="30"
                          FontSize="14"
                          BorderThickness="0"
                          CanUserResizeColumns="False"
                          CanUserResizeRows="False"
                          SelectionChanged="dgProdutos_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Id"
                                                Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Id}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Nome"
                                                Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Nome}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Código"
                                                Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CodigoProduto}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Valor"
                                                Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Valor}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</Window>
